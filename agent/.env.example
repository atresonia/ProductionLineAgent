ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── LLM provider selection ────────────────────────────────────────────────────
# MODEL_PROVIDER: "anthropic" (default) | "openai"
#   "openai" works with any OpenAI-compatible endpoint:
#   Together.ai, OpenRouter, Ollama, etc.
MODEL_PROVIDER=anthropic
MODEL_NAME=claude-opus-4-6

# Required only when MODEL_PROVIDER=openai
# Examples:
#   Together.ai  → https://api.together.xyz/v1
#   OpenRouter   → https://openrouter.ai/api/v1
#   Ollama local → http://localhost:11434/v1
OPENAI_BASE_URL=
OPENAI_API_KEY=

LOG_DIR=../logs
CHAOS_DIR=../chaos
CONFIG_DIR=../configs
ASSETS_DIR=../assets
DATA_DIR=../data
POSTMORTEM_DIR=../postmortems
POLL_INTERVAL=5
ERROR_RATE_THRESHOLD=15
LATENCY_THRESHOLD_MS=1500
MEMORY_DELTA_THRESHOLD=80

# Slack — outbound alerts (incoming webhook, for posting messages)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Slack — inbound watcher (bot token, for reading #incidents)
# Create a Slack app at api.slack.com/apps → OAuth & Permissions
# Bot token scopes needed: channels:history, chat:write
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
# Right-click #incidents in Slack → Copy link → last path segment is the ID
SLACK_INCIDENTS_CHANNEL_ID=C01234ABCDE
# How often to poll #incidents for new messages (seconds, default 15)
SLACK_POLL_INTERVAL=15

# Recall.ai — meeting bot transcription (Zoom, Teams, Meet, Webex, Slack Huddles)
# Sign up at https://www.recall.ai to get an API key
RECALL_API_KEY=
# Public base URL that Recall.ai will POST transcript webhooks to.
# For local dev use ngrok: ngrok http 8080  then set this to the ngrok URL.
WEBHOOK_BASE_URL=https://your-agent-host
# Port the webhook server listens on (default 8080)
WEBHOOK_PORT=8080
